# TruLoad Frontend Environment Variables

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:4000

# TruConnect local service URL (for scale data)
NEXT_PUBLIC_TRUCONNECT_URL=http://localhost:8080

# SSO / OAuth — central auth service for commercial weighing tenants
# Defaults in sso.ts if not set: https://sso.codevertexitsolutions.com / truload-ui
NEXT_PUBLIC_AUTH_API_URL=https://sso.codevertexitsolutions.com
NEXT_PUBLIC_SSO_CLIENT_ID=truload-ui

# Environment (development, staging, production)
NODE_ENV=development

# Superset Analytics (optional, for analytics embedding)
NEXT_PUBLIC_SUPERSET_URL=
NEXT_PUBLIC_SUPERSET_GUEST_TOKEN_ENDPOINT=/api/v1/analytics/guest-token
